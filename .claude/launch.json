{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ict-terminal",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "ict-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "port": 3001
    },
    {
      "name": "ict-verify",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port=5180", "--strictPort"],
      "port": 5180
    },
    {
      "name": "ict-worktree",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port=5174", "--strictPort"],
      "port": 5174
    }
  ]
}
